# Supabase loyiha sozlamalari
# Bu faylni nusxalab .env nomini bering va o'z qiymatlaringizni kiriting
# Supabase dashboard: https://supabase.com/dashboard

# Loyiha URL manzili (Supabase → Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Ommaviy kalit (Supabase → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
